#!/usr/bin/env bash
# Tekhton pipeline.conf — Project-specific configuration
#
# Place this file at:  <your-project>/.claude/pipeline.conf
# Lines starting with # are comments. Empty lines are ignored.
# Format: KEY=value (no spaces around =, quote strings with spaces)
#
# Review the Essential section below — most users only need the first 20 lines.
# All other sections have sensible defaults.

# Tekhton config version (do not edit manually)
# TEKHTON_CONFIG_VERSION="3.22"

PROJECT_NAME="My Project"
TEST_CMD="echo 'No test command configured — set TEST_CMD in pipeline.conf'"
ANALYZE_CMD="echo 'No analyze command configured — set ANALYZE_CMD in pipeline.conf'"
BUILD_CHECK_CMD=""
ARCHITECTURE_FILE="ARCHITECTURE.md"
PROJECT_RULES_FILE="CLAUDE.md"
# DESIGN_FILE=".tekhton/DESIGN.md"

# Tekhton artifact directory — all pipeline-managed files live here.
# CLAUDE.md stays at the project root (Claude Code requires it there).
# TEKHTON_DIR=".tekhton"

# ═══════════════════════════════════════════════════════════════════════════════
# Section 2: Models & Turns
# Defaults work well — tune after a few runs if needed
# ═══════════════════════════════════════════════════════════════════════════════

CLAUDE_STANDARD_MODEL="claude-sonnet-4-6"
CLAUDE_CODER_MODEL="claude-opus-4-6"
CLAUDE_JR_CODER_MODEL="claude-haiku-4-5"
CLAUDE_SCOUT_MODEL="claude-haiku-4-5"
CLAUDE_REVIEWER_MODEL="claude-sonnet-4-6"
CLAUDE_ARCHITECT_MODEL="claude-sonnet-4-6"
CLAUDE_TESTER_MODEL="claude-haiku-4-5"

CODER_MAX_TURNS=35
JR_CODER_MAX_TURNS=15
REVIEWER_MAX_TURNS=10
TESTER_MAX_TURNS=30
SCOUT_MAX_TURNS=20
DYNAMIC_TURNS_ENABLED=true

# Milestone mode overrides (uncomment to customize):
# MILESTONE_MAX_REVIEW_CYCLES=4
# MILESTONE_CODER_MAX_TURNS=70
# MILESTONE_JR_CODER_MAX_TURNS=30
# MILESTONE_REVIEWER_MAX_TURNS=15
# MILESTONE_TESTER_MAX_TURNS=60
# MILESTONE_TESTER_MODEL="claude-sonnet-4-6"
# MILESTONE_ACTIVITY_TIMEOUT_MULTIPLIER=3

# ═══════════════════════════════════════════════════════════════════════════════
# Section 3: Pipeline Behavior
# Advanced — most users never change these
# ═══════════════════════════════════════════════════════════════════════════════

REQUIRED_TOOLS="claude git"
MAX_REVIEW_CYCLES=2
CONTEXT_BUDGET_ENABLED=true
CONTEXT_BUDGET_PCT=50
CHARS_PER_TOKEN=4
CONTEXT_COMPILER_ENABLED=false

# Error pattern matching
ANALYZE_ERROR_PATTERN="error"
BUILD_ERROR_PATTERN="ERROR"

# Clarification and replanning
# CLARIFICATION_ENABLED=true
# REPLAN_ENABLED=true
# REPLAN_MODEL="opus"
# REPLAN_MAX_TURNS=50

# Turn exhaustion continuation
# CONTINUATION_ENABLED=true
# MAX_CONTINUATION_ATTEMPTS=3

# Transient error retry
# TRANSIENT_RETRY_ENABLED=true
# MAX_TRANSIENT_RETRIES=3
# TRANSIENT_RETRY_BASE_DELAY=30
# TRANSIENT_RETRY_MAX_DELAY=120

# Planning phase
# PLAN_INTERVIEW_MODEL="sonnet"
# PLAN_GENERATION_MODEL="sonnet"
# PLAN_INTERVIEW_MAX_TURNS=50
# PLAN_GENERATION_MAX_TURNS=30

# Human notes
NOTES_FILTER_CATEGORIES="BUG|FEAT|POLISH"

# Drift detection
# DRIFT_LOG_FILE=".tekhton/DRIFT_LOG.md"
# ARCHITECTURE_LOG_FILE=".tekhton/ARCHITECTURE_LOG.md"
# HUMAN_ACTION_FILE=".tekhton/HUMAN_ACTION_REQUIRED.md"
DRIFT_OBSERVATION_THRESHOLD=8
DRIFT_RUNS_SINCE_AUDIT_THRESHOLD=5
# NON_BLOCKING_LOG_FILE=".tekhton/NON_BLOCKING_LOG.md"
NON_BLOCKING_INJECTION_THRESHOLD=8

# Architect agent
ARCHITECT_ROLE_FILE=".claude/agents/architect.md"
ARCHITECT_MAX_TURNS=25
DEPENDENCY_CONSTRAINTS_FILE=""

# Dynamic turn bounds
# CODER_MIN_TURNS=15
# CODER_MAX_TURNS_CAP=200
# REVIEWER_MIN_TURNS=10
# REVIEWER_MAX_TURNS_CAP=30
# TESTER_MIN_TURNS=10
# TESTER_MAX_TURNS_CAP=100

# Agent exit detection
# AGENT_NULL_RUN_THRESHOLD=2
# AGENT_FILE_SCAN_DEPTH=8

# ═══════════════════════════════════════════════════════════════════════════════
# Section 4: Security
# Security is ON by default — adjust policy to your risk tolerance
# ═══════════════════════════════════════════════════════════════════════════════

# SPECIALIST_SECURITY_ENABLED=false
# SPECIALIST_SECURITY_MODEL="claude-sonnet-4-6"
# SPECIALIST_SECURITY_MAX_TURNS=8

# SPECIALIST_PERFORMANCE_ENABLED=false
# SPECIALIST_PERFORMANCE_MODEL="claude-sonnet-4-6"
# SPECIALIST_PERFORMANCE_MAX_TURNS=8

# SPECIALIST_API_ENABLED=false
# SPECIALIST_API_MODEL="claude-sonnet-4-6"
# SPECIALIST_API_MAX_TURNS=8

# AGENT_SKIP_PERMISSIONS=false

# Docs agent stage — optional post-coder/pre-security stage
# Uses Haiku to update README/docs/ based on the coder's diff
# DOCS_AGENT_ENABLED=false
# DOCS_AGENT_MODEL="claude-haiku-4-5-20251001"
# DOCS_AGENT_MAX_TURNS=10

# ═══════════════════════════════════════════════════════════════════════════════
# Section 5: Features
# Optional features — enable as needed
# ═══════════════════════════════════════════════════════════════════════════════

# REPO_MAP_ENABLED=false
# REPO_MAP_TOKEN_BUDGET=2048
# REPO_MAP_CACHE_DIR=".claude/index"
# REPO_MAP_LANGUAGES="auto"
# REPO_MAP_VENV_DIR=".claude/indexer-venv"
# REPO_MAP_HISTORY_ENABLED=true

# SERENA_ENABLED=false
# SERENA_PATH=".claude/serena"
# SERENA_LANGUAGE_SERVERS="auto"
# SERENA_STARTUP_TIMEOUT=30

# DASHBOARD_ENABLED=true
# DASHBOARD_REFRESH_INTERVAL=5
# DASHBOARD_MAX_TIMELINE_EVENTS=500
# DASHBOARD_HISTORY_DEPTH=50
# DASHBOARD_VERBOSITY="normal"
# Dashboard data lives in .claude/dashboard — add to .gitignore if desired

# --- UI Testing (Milestone 28) ---
# UI_TEST_CMD=""                  # E2E test command (e.g., "npx playwright test")
# UI_FRAMEWORK=""                 # auto | playwright | cypress | selenium | puppeteer | testing-library | detox
# UI_VALIDATION_ENABLED=true      # Enable UI validation gate when UI detected
# UI_TEST_TIMEOUT=120             # Seconds before UI test gate times out

# --- UI Validation (Milestone 29: headless browser smoke tests) ---
# UI_SERVE_CMD=""                    # Dev server command (e.g., "npm run dev")
# UI_SERVE_PORT=3000                 # Dev server port
# UI_SERVER_STARTUP_TIMEOUT=30       # Seconds to wait for server ready
# UI_VALIDATION_VIEWPORTS="1280x800,375x812"  # Viewport sizes
# UI_VALIDATION_TIMEOUT=30           # Seconds per page load timeout
# UI_VALIDATION_CONSOLE_SEVERITY=error  # error | warn
# UI_VALIDATION_FLICKER_THRESHOLD=0.05  # Pixel diff ratio for flicker warning
# UI_VALIDATION_RETRY=true           # Retry once on failure before rework
# UI_VALIDATION_SCREENSHOTS=true     # Save screenshots for review
# WATCHTOWER_SELF_TEST=true          # Auto-test dashboard when Watchtower enabled

SEED_CONTRACTS_ENABLED=false
# INLINE_CONTRACT_PATTERN=""
# INLINE_CONTRACT_SEARCH_CMD=""

# INTAKE_AGENT_ENABLED=true
# CLAUDE_INTAKE_MODEL="opus"
# INTAKE_MAX_TURNS=10
# INTAKE_CLARITY_THRESHOLD=40
# INTAKE_TWEAK_THRESHOLD=70

# CLEANUP_ENABLED=false
# CLEANUP_BATCH_SIZE=5
# CLEANUP_MAX_TURNS=15
# CLEANUP_TRIGGER_THRESHOLD=5

# MILESTONE_DAG_ENABLED=true
# MILESTONE_DIR=".claude/milestones"
# MILESTONE_MANIFEST="MANIFEST.cfg"
# MILESTONE_AUTO_MIGRATE=true
# MILESTONE_WINDOW_PCT=30
# MILESTONE_WINDOW_MAX_CHARS=20000
# MILESTONE_SPLIT_ENABLED=true
# MILESTONE_SPLIT_MODEL="claude-opus-4-6"
# MILESTONE_SPLIT_MAX_TURNS=15
# MILESTONE_SPLIT_THRESHOLD_PCT=120
# MILESTONE_AUTO_RETRY=true
# MILESTONE_MAX_SPLIT_DEPTH=3

# --- Auto-fix on test failure ---
# TESTER_FIX_ENABLED=false          # Auto-seed a fix run when tests fail (opt-in)
# TESTER_FIX_MAX_DEPTH=1            # Max recursive fix attempts (prevents infinite loops)
# TESTER_FIX_OUTPUT_LIMIT=4000      # Max chars of test output in fix task string

# TEST_BASELINE_ENABLED=true
# TEST_BASELINE_PASS_ON_PREEXISTING=false   # M92: default — pre-existing failures no longer auto-pass.
                                            # Set to true only if you genuinely cannot fix some tests (masks failures).

# --- Pre-coder clean sweep (M92) ---
# Before the coder runs, check if tests pass. If not, spawn a restricted fix
# agent to restore a clean baseline. The fix is non-fatal — if it cannot
# clean the suite, the coder proceeds and the stricter post-run gates surface
# the breakage. Disable for projects with intentionally failing tests.
# PRE_RUN_CLEAN_ENABLED=true
# PRE_RUN_FIX_MAX_TURNS=20
# PRE_RUN_FIX_MAX_ATTEMPTS=1

# ═══════════════════════════════════════════════════════════════════════════════
# Section 6: Quotas & Autonomy
# Controls for autonomous mode (--complete, --auto-advance)
# ═══════════════════════════════════════════════════════════════════════════════

# COMPLETE_MODE_ENABLED=true
# MAX_PIPELINE_ATTEMPTS=5
# AUTONOMOUS_TIMEOUT=7200
# MAX_AUTONOMOUS_AGENT_CALLS=20
# AUTONOMOUS_PROGRESS_CHECK=true

# AUTO_ADVANCE_ENABLED=false
# AUTO_ADVANCE_LIMIT=3
# AUTO_ADVANCE_CONFIRM=true
# MILESTONE_TAG_ON_COMPLETE=false
# MILESTONE_ARCHIVE_FILE=MILESTONE_ARCHIVE.md

# USAGE_THRESHOLD_PCT=0
# AUTO_COMMIT=true

# ═══════════════════════════════════════════════════════════════════════════════
# Section 7: Paths & Files
# File paths — rarely need changing
# ═══════════════════════════════════════════════════════════════════════════════

PIPELINE_STATE_FILE=".claude/PIPELINE_STATE.md"
LOG_DIR=".claude/logs"
CODER_ROLE_FILE=".claude/agents/coder.md"
REVIEWER_ROLE_FILE=".claude/agents/reviewer.md"
TESTER_ROLE_FILE=".claude/agents/tester.md"
JR_CODER_ROLE_FILE=".claude/agents/jr-coder.md"
# MIGRATION_AUTO=true

# ═══════════════════════════════════════════════════════════════════════════════
# Section 8: Human Notes Triage
# Sizing gate for human notes — detects oversized notes and offers promotion
# ═══════════════════════════════════════════════════════════════════════════════

# HUMAN_NOTES_TRIAGE_ENABLED=true          # Run triage gate before note execution
# HUMAN_NOTES_TRIAGE_MODEL=haiku           # Model for agent escalation (haiku recommended)
# HUMAN_NOTES_PROMOTE_THRESHOLD=20         # Est. turns above which to recommend promotion
# HUMAN_NOTES_PROMOTE_MODE=confirm         # confirm = ask user; auto = promote silently
