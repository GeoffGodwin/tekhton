#!/usr/bin/env bash
# =============================================================================
# pipeline.conf — Project-specific configuration for the Tekhton pipeline
#
# This is the ONLY file you need to edit to adapt the pipeline to a new project.
# All values below are read by Tekhton's lib/config.sh at startup.
#
# Place this file at:  <your-project>/.claude/pipeline.conf
#
# Lines starting with # are comments. Empty lines are ignored.
# Format: KEY=value (no spaces around =, quote strings with spaces)
# =============================================================================

# --- Project identity --------------------------------------------------------

# Display name used in terminal output and branding
PROJECT_NAME="My Project"

# One-line description shown in --help
PROJECT_DESCRIPTION="multi-agent development pipeline"

# --- Required CLI tools ------------------------------------------------------
# Space-separated list of commands that must be on PATH before the pipeline runs
REQUIRED_TOOLS="claude git"

# --- Agent models ------------------------------------------------------------
# Every agent has its own model variable. Share models across agents to save
# cost, or promote individual agents as quality demands.
#
#   Agent            Variable                  Default usage
#   ───────────────  ────────────────────────  ─────────────────────────────────
#   Senior Coder     CLAUDE_CODER_MODEL        Complex implementation
#   Jr Coder         CLAUDE_JR_CODER_MODEL     Simple fixes, build-gate rework
#   Scout            CLAUDE_SCOUT_MODEL        File discovery, complexity est.
#   Reviewer         CLAUDE_STANDARD_MODEL     Code review + verdict
#   Architect        CLAUDE_ARCHITECT_MODEL    Drift audit, remediation planning
#   Tester           CLAUDE_TESTER_MODEL       Test authoring (upgradeable in --milestone)
CLAUDE_CODER_MODEL="claude-opus-4-6"
CLAUDE_JR_CODER_MODEL="claude-haiku-4-5"
CLAUDE_SCOUT_MODEL="claude-haiku-4-5"
CLAUDE_STANDARD_MODEL="claude-sonnet-4-6"
CLAUDE_ARCHITECT_MODEL="claude-sonnet-4-6"
CLAUDE_TESTER_MODEL="claude-haiku-4-5"

# --- Agent permissions -------------------------------------------------------
# By default, agents use --allowedTools with least-privilege profiles.
# Each agent role gets only the Claude CLI tools it needs (e.g., reviewers
# can read and write reports but cannot run bash or edit code).
# Destructive operations (git push, rm -rf, curl, wget) are always blocked.
#
# Set AGENT_SKIP_PERMISSIONS=true to restore the old --dangerously-skip-permissions
# behavior. NOT recommended — agents will have unrestricted filesystem and bash access.
# AGENT_SKIP_PERMISSIONS=false

# --- Turn limits (normal mode) ----------------------------------------------
CODER_MAX_TURNS=35
JR_CODER_MAX_TURNS=15
REVIEWER_MAX_TURNS=10
TESTER_MAX_TURNS=30
SCOUT_MAX_TURNS=20
SEED_CONTRACTS_MAX_TURNS=20

# --- Turn limits (milestone mode overrides) ----------------------------------
# These override normal limits when --milestone is passed.
# Defaults: 2× normal turns, upgraded tester model.
# Uncomment and customize if the defaults don't suit your project.
# MILESTONE_MAX_REVIEW_CYCLES=4
# MILESTONE_CODER_MAX_TURNS=70
# MILESTONE_JR_CODER_MAX_TURNS=30
# MILESTONE_REVIEWER_MAX_TURNS=15
# MILESTONE_TESTER_MAX_TURNS=60
# MILESTONE_TESTER_MODEL="claude-sonnet-4-6"

# --- Review loop -------------------------------------------------------------
MAX_REVIEW_CYCLES=2

# --- Build / test / analyze commands -----------------------------------------
# These commands are run by the pipeline directly and injected into prompts.
# Adapt for your tech stack (e.g., cargo, npm, go, pytest, make).

# Static analysis command — must exit 0 on clean, nonzero on issues
ANALYZE_CMD="echo 'No analyze command configured — set ANALYZE_CMD in pipeline.conf'"

# Test runner command
TEST_CMD="echo 'No test command configured — set TEST_CMD in pipeline.conf'"

# Compile check command(s) — a quick "does it build?" gate.
# Use || to chain fallbacks. Set to "" to skip compile check.
BUILD_CHECK_CMD=""

# Pattern to detect errors in analyze output (grep -E pattern)
ANALYZE_ERROR_PATTERN="error"

# Pattern to detect errors in compile output (grep pattern)
BUILD_ERROR_PATTERN="ERROR"

# --- Pipeline file paths -----------------------------------------------------
PIPELINE_STATE_FILE=".claude/PIPELINE_STATE.md"
LOG_DIR=".claude/logs"

# --- Agent role files (relative to repo root) --------------------------------
# These markdown files define each agent's persona, rules, and constraints.
# The pipeline checks these exist at startup and injects them into prompts.
CODER_ROLE_FILE=".claude/agents/coder.md"
REVIEWER_ROLE_FILE=".claude/agents/reviewer.md"
TESTER_ROLE_FILE=".claude/agents/tester.md"
JR_CODER_ROLE_FILE=".claude/agents/jr-coder.md"

# --- Context files (optional — set to "" to skip) ---------------------------
# These files are injected into agent prompts when they exist.
ARCHITECTURE_FILE="ARCHITECTURE.md"
GLOSSARY_FILE=""
PROJECT_RULES_FILE="CLAUDE.md"

# --- Design document (optional — enables design cross-referencing) -----------
DESIGN_FILE=""

# --- Architecture drift configuration ----------------------------------------
# Path to the architecture decision log (records accepted ACPs)
ARCHITECTURE_LOG_FILE="ARCHITECTURE_LOG.md"

# Path to the drift observation log (accumulated across runs)
DRIFT_LOG_FILE="DRIFT_LOG.md"

# Path to the human action required file (design doc changes needed)
HUMAN_ACTION_FILE="HUMAN_ACTION_REQUIRED.md"

# Trigger architect audit after this many unresolved drift observations
DRIFT_OBSERVATION_THRESHOLD=8

# Trigger architect audit after this many pipeline runs since last audit
DRIFT_RUNS_SINCE_AUDIT_THRESHOLD=5

# Non-blocking reviewer notes log file
NON_BLOCKING_LOG_FILE="NON_BLOCKING_LOG.md"

# Inject accumulated non-blocking notes into coder prompt when count exceeds this
NON_BLOCKING_INJECTION_THRESHOLD=8

# --- Human notes configuration ----------------------------------------------
# Valid categories for --notes-filter (pipe-separated for case matching)
NOTES_FILTER_CATEGORIES="BUG|FEAT|POLISH"

# --- Architect agent ---------------------------------------------------------
# Role file for the architect audit agent (relative to repo root)
ARCHITECT_ROLE_FILE=".claude/agents/architect.md"

# Turn limits for architect audit
ARCHITECT_MAX_TURNS=25
# MILESTONE_ARCHITECT_MAX_TURNS=50

# Model is set in the Agent models section above (CLAUDE_ARCHITECT_MODEL).

# Dependency constraint manifest (empty = skip). See examples/ for format.
DEPENDENCY_CONSTRAINTS_FILE=""

# --- Agent exit detection ----------------------------------------------------
# When an agent uses ≤ this many turns AND exits non-zero, it's flagged as a
# "null run" (died during discovery without doing productive work).
# AGENT_NULL_RUN_THRESHOLD=2

# --- Dynamic turn limits ----------------------------------------------------
# When enabled, the scout estimates task complexity and adjusts turn limits
# for coder, reviewer, and tester stages. Recommended values are clamped to
# [MIN, MAX_CAP] bounds. Set to false to always use the static limits above.
DYNAMIC_TURNS_ENABLED=true

# Bounds for dynamic turn adjustment (only used when DYNAMIC_TURNS_ENABLED=true)
# CODER_MIN_TURNS=15
# CODER_MAX_TURNS_CAP=200
# REVIEWER_MIN_TURNS=5
# REVIEWER_MAX_TURNS_CAP=30
# TESTER_MIN_TURNS=10
# TESTER_MAX_TURNS_CAP=100

# --- Planning phase (--plan) -------------------------------------------------
# These keys configure the interactive planning phase. They are optional —
# sensible defaults are applied when not set.

# Model for the interview agent (conversational, needs good reasoning)
# PLAN_INTERVIEW_MODEL="sonnet"

# Model for the CLAUDE.md generation agent (needs strong structure)
# PLAN_GENERATION_MODEL="sonnet"

# Override both interview and generation models at once
# CLAUDE_PLAN_MODEL="sonnet"

# Max turns for the interview conversation
# PLAN_INTERVIEW_MAX_TURNS=50

# Max turns for CLAUDE.md generation
# PLAN_GENERATION_MAX_TURNS=30

# --- Seed contracts ----------------------------------------------------------
# Enable inline contract seeding (adds contract doc comments to source files)
SEED_CONTRACTS_ENABLED=false

# Required when SEED_CONTRACTS_ENABLED=true:
#   INLINE_CONTRACT_PATTERN    — keyword the seeder and reviewer look for
#                                (e.g. "System:" for Dart, "Contract:" for TypeScript)
#   INLINE_CONTRACT_SEARCH_CMD — shell command to find all public declarations
#                                to annotate (e.g. grep -rn "^class\|^  void" lib/)
# INLINE_CONTRACT_PATTERN=""
# INLINE_CONTRACT_SEARCH_CMD=""
